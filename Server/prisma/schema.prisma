generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id            String    @id @default(uuid())
  name          String
  login_id      String    @unique
  email         String    @unique
  password_hash String
  created_at    DateTime  @default(now())
  last_login    DateTime?

  @@map("admins")
}

model Owner {
  id                    String               @id @default(uuid())
  business_name         String
  business_type         String
  owner_name            String
  email                 String               @unique
  phone                 String               @unique
  password_hash         String
  address               String
  city                  String
  state                 String
  pincode               String
  gstin                 String?
  fssai_license         String?
  table_count           Int                  @default(10)
  unique_slug           String               @unique
  is_active             Boolean              @default(true)
  subscription_status   String               @default("trial")
  subscription_expires  DateTime?
  payment_method_pref   String               @default("both")
  upi_id                String?
  upi_qr_image_url      String?
  razorpay_key_id       String?
  razorpay_key_secret   String?
  profile_photo_url     String?
  created_at            DateTime             @default(now())
  updated_at            DateTime             @updatedAt
  categories            Category[]
  food_items            FoodItem[]
  orders                Order[]
  password_reset_tokens PasswordResetToken[]
  subscriptions         Subscription[]

  @@map("owners")
}

model Category {
  id         String     @id @default(uuid())
  owner_id   String
  name_en    String
  name_hi    String
  sort_order Int        @default(0)
  created_at DateTime   @default(now())
  owner      Owner      @relation(fields: [owner_id], references: [id], onDelete: Cascade)
  food_items FoodItem[]

  @@map("categories")
}

model FoodItem {
  id             String      @id @default(uuid())
  owner_id       String
  category_id    String?
  name_en        String
  name_hi        String
  description_en String?
  description_hi String?
  price          Float
  photo_url      String?
  is_veg         Boolean     @default(true)
  is_available   Boolean     @default(true)
  sort_order     Int         @default(0)
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt
  category       Category?   @relation(fields: [category_id], references: [id])
  owner          Owner       @relation(fields: [owner_id], references: [id], onDelete: Cascade)
  order_items    OrderItem[]

  @@map("food_items")
}

model Order {
  id                  String      @id @default(uuid())
  owner_id            String?
  order_number        String
  table_number        String
  customer_name       String?
  subtotal            Float
  tax_amount          Float       @default(0)
  total_amount        Float
  payment_method      String?
  payment_status      String      @default("pending")
  razorpay_order_id   String?
  razorpay_payment_id String?
  language_used       String      @default("en")
  notes               String?
  created_at          DateTime    @default(now())
  items               OrderItem[]
  owner               Owner?      @relation(fields: [owner_id], references: [id])

  @@map("orders")
}

model OrderItem {
  id           String    @id @default(uuid())
  order_id     String
  food_item_id String?
  item_name_en String
  item_name_hi String
  quantity     Int
  unit_price   Float
  total_price  Float
  food_item    FoodItem? @relation(fields: [food_item_id], references: [id])
  order        Order     @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@map("order_items")
}

model Subscription {
  id                       String           @id @default(uuid())
  owner_id                 String
  plan_id                  String
  amount_paid              Float
  currency                 String           @default("INR")
  razorpay_payment_id      String?
  razorpay_subscription_id String?
  start_date               DateTime
  end_date                 DateTime
  status                   String           @default("active")
  created_at               DateTime         @default(now())
  owner                    Owner            @relation(fields: [owner_id], references: [id], onDelete: Cascade)
  plan                     SubscriptionPlan @relation(fields: [plan_id], references: [id])

  @@map("subscriptions")
}

model SubscriptionPlan {
  id            String         @id @default(uuid())
  plan_name     String
  price_monthly Float
  trial_days    Int            @default(30)
  features      String?
  is_active     Boolean        @default(true)
  created_at    DateTime       @default(now())
  subscriptions Subscription[]

  @@map("subscription_plans")
}

model AuditLog {
  id          String   @id @default(uuid())
  actor_id    String
  actor_role  String
  action      String
  target_type String?
  target_id   String?
  details     String?
  ip_address  String?
  user_agent  String?
  created_at  DateTime @default(now())

  @@map("audit_logs")
}

model PasswordResetToken {
  id         String   @id @default(uuid())
  owner_id   String
  token      String   @unique
  expires_at DateTime
  used       Boolean  @default(false)
  created_at DateTime @default(now())
  owner      Owner    @relation(fields: [owner_id], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}
