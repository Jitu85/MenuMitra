datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

model Admin {
  id            String    @id @default(uuid())
  name          String
  login_id      String    @unique
  email         String    @unique
  password_hash String
  created_at    DateTime  @default(now())
  last_login    DateTime?

  @@map("admins")
}

model Owner {
  id                   String               @id @default(uuid())
  business_name        String
  business_type        String // 'hotel','restaurant','tea_stall','cafe','dhaba','other'
  owner_name           String
  email                String               @unique
  phone                String               @unique
  password_hash        String
  address              String
  city                 String
  state                String
  pincode              String
  gstin                String?
  fssai_license        String?
  table_count          Int                  @default(10)
  unique_slug          String               @unique
  is_active            Boolean              @default(true)
  subscription_status  String               @default("trial") // 'active','expired','trial','suspended'
  subscription_expires DateTime?
  payment_method_pref  String               @default("both") // 'upi_qr','razorpay','both'
  upi_id               String?
  upi_qr_image_url     String?
  razorpay_key_id      String?
  razorpay_key_secret  String?
  profile_photo_url    String?
  created_at           DateTime             @default(now())
  updated_at           DateTime             @updatedAt
  categories           Category[]
  food_items           FoodItem[]
  orders               Order[]
  subscriptions        Subscription[]
  password_reset_tokens PasswordResetToken[]

  @@map("owners")
}

model Category {
  id         String     @id @default(uuid())
  owner_id   String
  owner      Owner      @relation(fields: [owner_id], references: [id], onDelete: Cascade)
  name_en    String
  name_hi    String
  sort_order Int        @default(0)
  created_at DateTime   @default(now())
  food_items FoodItem[]

  @@map("categories")
}

model FoodItem {
  id             String      @id @default(uuid())
  owner_id       String
  owner          Owner       @relation(fields: [owner_id], references: [id], onDelete: Cascade)
  category_id    String?
  category       Category?   @relation(fields: [category_id], references: [id], onDelete: SetNull)
  name_en        String
  name_hi        String
  description_en String?
  description_hi String?
  price          Float
  photo_url      String?
  is_veg         Boolean     @default(true)
  is_available   Boolean     @default(true)
  sort_order     Int         @default(0)
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt
  order_items    OrderItem[]

  @@map("food_items")
}

model Order {
  id                  String      @id @default(uuid())
  owner_id            String?
  owner               Owner?      @relation(fields: [owner_id], references: [id], onDelete: SetNull)
  order_number        String
  table_number        String
  customer_name       String?
  subtotal            Float
  tax_amount          Float       @default(0)
  total_amount        Float
  payment_method      String? // 'upi_qr','razorpay'
  payment_status      String      @default("pending") // 'pending','paid','failed'
  razorpay_order_id   String?
  razorpay_payment_id String?
  language_used       String      @default("en")
  notes               String?
  created_at          DateTime    @default(now())
  items               OrderItem[]

  @@map("orders")
}

model OrderItem {
  id           String    @id @default(uuid())
  order_id     String
  order        Order     @relation(fields: [order_id], references: [id], onDelete: Cascade)
  food_item_id String?
  food_item    FoodItem? @relation(fields: [food_item_id], references: [id], onDelete: SetNull)
  item_name_en String
  item_name_hi String
  quantity     Int
  unit_price   Float
  total_price  Float

  @@map("order_items")
}

model Subscription {
  id                       String           @id @default(uuid())
  owner_id                 String
  owner                    Owner            @relation(fields: [owner_id], references: [id], onDelete: Cascade)
  plan_id                  String
  plan                     SubscriptionPlan @relation(fields: [plan_id], references: [id])
  amount_paid              Float
  currency                 String           @default("INR")
  razorpay_payment_id      String?
  razorpay_subscription_id String?
  start_date               DateTime
  end_date                 DateTime
  status                   String           @default("active") // 'active','expired','cancelled'
  created_at               DateTime         @default(now())

  @@map("subscriptions")
}

model SubscriptionPlan {
  id            String         @id @default(uuid())
  plan_name     String // "MenuMitra Standard"
  price_monthly Float // 100.00
  trial_days    Int            @default(30)
  features      String? // Serialized JSON string of features
  is_active     Boolean        @default(true)
  created_at    DateTime       @default(now())
  subscriptions Subscription[]

  @@map("subscription_plans")
}

model AuditLog {
  id          String   @id @default(uuid())
  actor_id    String
  actor_role  String // 'admin','owner'
  action      String
  target_type String?
  target_id   String?
  details     String? // String details or serialized JSON
  ip_address  String?
  user_agent  String?
  created_at  DateTime @default(now())

  @@map("audit_logs")
}

model PasswordResetToken {
  id         String   @id @default(uuid())
  owner_id   String
  owner      Owner    @relation(fields: [owner_id], references: [id], onDelete: Cascade)
  token      String   @unique
  expires_at DateTime
  used       Boolean  @default(false)
  created_at DateTime @default(now())

  @@map("password_reset_tokens")
}
